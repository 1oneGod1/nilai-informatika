{
  "rules": {
    ".read": false,
    ".write": false,
    "siswa": {
      ".read": true,
      ".write": "auth != null"
    },
    "guru": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'andi.purba@sdh.or.id')",
        "isVerified": {
          ".write": "auth != null && auth.token.email === 'andi.purba@sdh.or.id'"
        },
        "verifiedBy": {
          ".write": "auth != null && auth.token.email === 'andi.purba@sdh.or.id'"
        },
        "verifiedAt": {
          ".write": "auth != null && auth.token.email === 'andi.purba@sdh.or.id'"
        }
      }
    }
  }
}
