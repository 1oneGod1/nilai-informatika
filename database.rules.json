{
  "rules": {
    ".read": false,
    ".write": false,
    "siswa": {
      ".read": true,
      ".write": "auth != null",
      "$siswaId": {
        "password": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().length >= 6"
        },
        "pendingPassword": {
          ".write": true,
          ".validate": "!newData.exists() || (newData.isString() && newData.val().length >= 6)"
        },
        "pendingPasswordAt": {
          ".write": true,
          ".validate": "!newData.exists() || newData.isNumber()"
        }
      }
    },
    "guru": {
      ".read": "auth != null",
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'andi.purba@sdh.or.id' || auth.token.email === 'pandapotanandi@gmail.com')",
        "isVerified": {
          ".write": "auth != null && (auth.token.email === 'andi.purba@sdh.or.id' || auth.token.email === 'pandapotanandi@gmail.com')"
        },
        "verifiedBy": {
          ".write": "auth != null && (auth.token.email === 'andi.purba@sdh.or.id' || auth.token.email === 'pandapotanandi@gmail.com')"
        },
        "verifiedAt": {
          ".write": "auth != null && (auth.token.email === 'andi.purba@sdh.or.id' || auth.token.email === 'pandapotanandi@gmail.com')"
        }
      }
    }
  }
}
